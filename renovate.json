{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":maintainLockFilesMonthly"
  ],
  "baseBranchPatterns": [
    "main"
  ],
  "labels": [
    "dependencies"
  ],
  "schedule": [
    "before 5am on the first day of the month"
  ],
  "prHourlyLimit": 0,
  "rebaseWhen": "conflicted",
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "description": "GitHub Actions: no automerge",
      "matchManagers": [
        "github-actions"
      ],
      "automerge": false
    },
    {
      "description": "Python deps: bump version floors",
      "matchManagers": [
        "pep621"
      ],
      "rangeStrategy": "bump"
    },
    {
      "description": "Pre-commit hooks: no automerge",
      "matchManagers": [
        "pre-commit"
      ],
      "automerge": false
    },
    {
      "description": "PyPI: 3-day stability gate",
      "matchDatasources": [
        "pypi"
      ],
      "minimumReleaseAge": "3 days"
    }
  ]
}
